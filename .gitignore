# Podcast data — NOT distributed with the repo.
# Transcripts are someone else's content; the index is derived from them.
# Users bring their own transcripts and run `python -m indexing.build_index`
# to regenerate these locally. See README for details.
backend/data/transcripts/
backend/data/index/
backend/data/episodes.json
backend/data/utterances.json
backend/data/matches.json

